}

‚ąá (params) renderChar ch {
  n ‚Üź ch-@\0
  ch ‚Üź if ((n ‚Č• 33 and n ‚Č§ 126) and n ‚Č† 92) {
    @@ , ch
  } else {
    "@\\u" , toHex n
  }
  <ch
}

stringReplacements ‚Üź {(‚ćĶ+@\0) (‚ćĶ+@\u2400)} ‚Üď‚ćĘ(10‚Üď) ‚ć≥0x20

