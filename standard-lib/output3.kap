cutVerticalResult ‚áź {
  m ‚Üź :metadata ‚ąä ‚ćļ
  arrayMaxHeight ‚Üź ‚ÜĎ‚Üďsysparam 'kap:rendererParameters
  (startRowIndex endRowIndex) ‚Üź arrayMaxHeight
  dimensions ‚Üź ‚ćī‚ćĶ
  if ((+/arrayMaxHeight) < ‚ÜĎ‚ćī‚ćĶ) {
    { if (m) {
        { ‚ćĶ ; :vclip 1 (‚ÜĎ‚Üďdimensions) }‚ćĘ((‚äā startRowIndex 0)‚äá) ‚ćĶ
      } else {
        ‚ćĶ
