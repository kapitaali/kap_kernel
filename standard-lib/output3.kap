trimVert ‚áź {
  vertSizes ‚Üź ¬Į1‚Üď‚ćī‚ćĶ
  arrayMaxHeight ‚Üź ‚ÜĎ‚Üďsysparam 'kap:rendererParameters
  h ‚Üź +/arrayMaxHeight
  ‚ćĚ Compute the dimension where splitting may be needed.
  d ‚Üź 2+/ h > √ó\‚ćĘ‚ĆĹvertSizes,1
  ‚ćĚ d is now an array where each value represents how to treat the corresponding
  ‚ćĚ axis. The possible values are:
  ‚ćĚ   0 - keep the first and last row
  ‚ćĚ   1 - keep the number of rows from arrayMaxHeight
  ‚ćĚ   2 - keep the axis unchanged
  {
    src ‚Üź ‚ćļ
    (axis mode) ‚Üź ‚ćĶ
    when {
      (mode‚Č°0) { if (vertSizes[axis] = 1) { src } else { (1‚ÜĎ[axis] src) ,[axis] ¬Į1‚ÜĎ[axis] src } }
      (mode‚Č°1) { if (vertSizes[axis] ‚Č§ h) { src } else { (arrayMaxHeight[0]‚ÜĎ[axis] src) ,[axis] (-arrayMaxHeight[1])‚ÜĎ[axis] src } }
      (mode‚Č°2) { src }
      (1)      { throw "Invalid mode: " mode }
    }
  }/ (‚äā‚ćĶ),(‚ć≥‚ČĘd),¬®d
}

trimHoriz ‚áź {
  ‚ćĚ If the width of ‚ćĶ is wider than can possibly fit
  ‚ćĚ in a reasonable amount of screen space (as defined by arrayMaxWidth),
  ‚ćĚ remove the middle part.
  ‚ćĚ Later, the middle will be trimmed and replaced with periods anyway.
  ‚ćĚ Finally, call trimVert to perform a similar action on the
  ‚ćĚ remaining dimensions.
  ‚ćĚ
  ‚ćĚ ‚ćļ is the minimum width of a single column. For regular arrays, this
  ‚ćĚ is usually 2 (one character for the cell content and one for the space
  ‚ćĚ between cells). For character arrays, this is 1.
  arrayMaxWidth ‚Üź ‚ÜĎsysparam 'kap:rendererParameters
  if ((‚ÜĎ‚ĆĹ‚ćī‚ćĶ) > (+/arrayMaxWidth)√∑2) {
    ((‚ĆąarrayMaxWidth[0]√∑‚ćļ)‚ÜĎ[¬Į1+‚ČĘ‚ćī‚ćĶ])¬ę,¬Ľ((-‚ĆąarrayMaxWidth[1]√∑‚ćļ)‚ÜĎ[¬Į1+‚ČĘ‚ćī‚ćĶ]) ‚ćĶ
  } else {
    ‚ćĶ
  }
}

renderArray ‚áź {
  isChars ‚Üź int:isKapMultidimensionalString ‚ćĶ

  hasColLabels ‚Üź (¬Į1+‚ČĘ‚ćī‚ćĶ) int:hasLabels ‚ćĶ

  if (isChars and 1=‚ČĘ‚ćī‚ćĶ) {
    ‚ćļ renderString ‚ćĶ
  } else {
    (header f d) ‚Üź if (~hasColLabels and isChars) {
      trimmed0 ‚Üź (1 trimHoriz) trimVert ‚ćĶ
      fRes0 ‚Üź (‚äā‚ć§2) ((¬Į1,¬Į2‚ÜĎ1,‚ćītrimmed0) ‚ćī trimmed0) , @‚Ēā
      ‚ć¨ fRes0 (‚ćītrimmed0)
    } else {
      trimmed1 ‚Üź (2 trimHoriz) trimVert ‚ćĶ
      d ‚Üź ‚ćītrimmed1

      labelsResult ‚Üź labels trimmed1
      colLabels ‚Üź < <¬® labelsResult

      v0 ‚Üź (‚äā‚ćļ) formatInt¬® trimmed1
      ‚ćĚ The top row contains the header (which may be discarded later), and the remaining
      ‚ćĚ rows contains the content of the the array. Split these out into their own variables.
      (headerRes aligned) ‚Üź (1‚ÜĎ)¬ę,‚ć•‚äā¬Ľ(1 0‚Üď) alignCells colLabels ‚ć™ ¬Į1 (‚ÜĎ‚ĆĹd) ‚ćī v0

      ‚ćĚ Concatenate the cells, add the right border and drop the leading space
      fRes1 ‚Üź (‚ć™/,/(¬Į1,(¬Į2‚ÜĎ1,d)) ‚ćī aligned) (0 1‚Üď,)¬® @‚Ēā

      headerRes fRes1 (‚ćītrimmed1)
    }

    w ‚Üź ‚ÜĎ‚Üď‚ćī‚ÜĎf

    top ‚Üź if (hasColLabels) {
      headerTop ‚Üź (¬Į1‚Üď ‚ÜĎ ,/ {((¬Į1+‚ÜĎ‚Üď‚ćī‚ćĶ) ‚ćī @‚ĒÄ) , @‚Ē¨}¬® header) , @‚Ēź
      headerCentre ‚Üź ‚ÜĎ ,/ {(0 1 ‚Üď ‚ćĶ) , @‚Ēā}¬® header
      headerBottom ‚Üź ("‚Üí" , 1‚Üď  ¬Į1‚Üď ‚ÜĎ ,/ {((¬Į1+‚ÜĎ‚Üď‚ćī‚ćĶ) ‚ćī @‚ĒÄ) , @‚Ēī}¬® header) , @‚Ē§
      q ‚Üź headerTop ‚ć™ headerCentre ‚ć™ headerBottom
    } else {
      < "‚Üí" , ((w-2) ‚ćī @‚ĒÄ) ,"‚Ēź"
    }
    bottom ‚Üź < ((w-1) ‚ćī @‚ĒÄ) ,"‚Ēė"
    separator ‚Üź < "‚Üí" , ((w-2) ‚ćī @‚ĒÄ) , "‚Ē§"
    res ‚Üź {top‚ć™‚ćĶ‚ć™bottom} ‚ÜĎ ‚ć™‚ĆŅ‚ć™ ¬Į1‚Üď , f ,[0.5] ‚äāseparator

    ‚ćĚ To draw the layers to the left, first determine the number of layers and their sizes.
    ds ‚Üź ¬Į2‚Üďd

    ‚ćĚ Compute the number of layer indicators for each layer
    layerPos ‚Üź ‚ĆĹ1,√ó\ds

    makeVerticalLayer ‚áź {
      ‚ćĚ Split content in groups of size ‚ćĶ, and compute height of each group
      sizes ‚Üź +/‚ČĘ¬® ¬Į1 ‚ćĶ ‚ćī f
      ‚ćĚ Create a sequence of vertical bars according to the sizes,
      ‚ćĚ and end with a split symbol. Finally remove the last instance.
      coverage ‚Üź ‚ćĶ-1
      vertArrow ‚Üź ‚ćļ ‚Ć∑ "‚Ēā‚Üď"
      centre ‚Üź ¬Į1‚Üď,/ {( vertArrow , (‚ćĶ+coverage-1) ‚ćī @‚Ēā) , @‚Ēú}¬® sizes
      ‚ć™ ,/ @‚ĒĆ , centre , @‚ĒĒ
    }

    verticalAxisIndicator ‚Üź ((0‚Ćą¬Į1+‚ČĘlayerPos) ‚ćī 0) , (1 ‚Č† ‚ČĘd)
    cornerContent ‚Üź if (hasColLabels) {
      ((¬Į1+‚ČĘtop) (¬Į1+‚ČĘlayerPos) ‚ćī @\s) , ‚ć™ @‚ĒĆ,(¬Į2+‚ČĘtop) ‚ćī @‚Ēā
    } else {
      0 (‚ČĘlayerPos) ‚ćī @\s
    }
    (cornerContent ‚ć™ {<<hasColLabels‚Ć∑"‚ĒĆ‚Ēú"}‚ćĘ(1 ¬Į1‚ÜĎ) (,/ verticalAxisIndicator makeVerticalLayer¬® layerPos)) , res
  }
}

